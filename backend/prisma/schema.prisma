generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole { STUDENT ADMIN }
enum ProjectStatus { DRAFT ACTIVE ARCHIVED }
enum ContentStatus { GENERATED SAVED EXPORTED }
enum AIRequestStatus { SUCCESS FAILED }

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  passwordHash       String?
  avatarUrl          String?
  googleId           String?  @unique
  role               UserRole @default(STUDENT)
  preferredFieldId   String?
  preferredField     AcademicField? @relation(fields: [preferredFieldId], references: [id])
  resetTokenHash     String?
  resetTokenExpiresAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  projects           ResearchProject[]
  sessions           ResearchSession[]
  savedProjects      SavedProject[]
  activities         UserActivityLog[]
  aiRequests         AIRequest[]
  notifications      Notification[]

  @@index([email])
}

model AcademicField {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  projects    ResearchProject[]
  templates   ResearchTemplate[]
  modules     AcademicFieldModule[]
}

model ResearchModule {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  orderIndex  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fields      AcademicFieldModule[]
  templates   ResearchTemplate[]
  contents    GeneratedContent[]
  sessions    ResearchSession[]
}

model AcademicFieldModule {
  id              String @id @default(cuid())
  academicFieldId String
  researchModuleId String
  enabled         Boolean @default(true)
  academicField   AcademicField @relation(fields: [academicFieldId], references: [id], onDelete: Cascade)
  researchModule  ResearchModule @relation(fields: [researchModuleId], references: [id], onDelete: Cascade)

  @@unique([academicFieldId, researchModuleId])
  @@index([academicFieldId])
  @@index([researchModuleId])
}

model ResearchTemplate {
  id              String @id @default(cuid())
  academicFieldId String
  researchModuleId String
  title           String
  systemPrompt    String
  userPrompt      String
  temperature     Float @default(0.7)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  academicField   AcademicField @relation(fields: [academicFieldId], references: [id], onDelete: Cascade)
  researchModule  ResearchModule @relation(fields: [researchModuleId], references: [id], onDelete: Cascade)

  @@unique([academicFieldId, researchModuleId])
  @@index([academicFieldId, researchModuleId])
}

model ResearchProject {
  id              String @id @default(cuid())
  userId          String
  academicFieldId String
  title           String
  description     String
  status          ProjectStatus @default(DRAFT)
  tags            String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  academicField   AcademicField @relation(fields: [academicFieldId], references: [id])
  contents        GeneratedContent[]
  sessions        ResearchSession[]
  savedProjects   SavedProject[]

  @@index([userId, createdAt])
  @@index([academicFieldId])
}

model GeneratedContent {
  id              String @id @default(cuid())
  projectId       String?
  userId          String
  academicFieldId String
  researchModuleId String
  title           String
  input           Json
  content         String
  status          ContentStatus @default(GENERATED)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         ResearchProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  researchModule  ResearchModule @relation(fields: [researchModuleId], references: [id])

  @@index([userId, createdAt])
  @@index([academicFieldId, researchModuleId])
}

model ResearchSession {
  id              String @id @default(cuid())
  userId          String
  projectId       String?
  researchModuleId String?
  title           String
  messages        Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         ResearchProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  researchModule  ResearchModule? @relation(fields: [researchModuleId], references: [id])

  @@index([userId, updatedAt])
}

model SavedProject {
  id        String @id @default(cuid())
  userId    String
  projectId String
  note      String?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
}

model UserActivityLog {
  id        String @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AIRequest {
  id              String @id @default(cuid())
  userId          String
  provider        String
  model           String
  academicFieldId String?
  researchModuleId String?
  promptTokens    Int @default(0)
  completionTokens Int @default(0)
  status          AIRequestStatus
  errorMessage    String?
  createdAt       DateTime @default(now())

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Notification {
  id        String @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}
